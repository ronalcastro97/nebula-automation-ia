---
const steps = [
  {
    number: '01',
    title: 'Análisis',
    desc: 'Analizamos tus procesos actuales e identificamos qué se puede automatizar para maximizar tu eficiencia.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>`,
  },
  {
    number: '02',
    title: 'Diseño',
    desc: 'Diseñamos los flujos de automatización y configuramos las integraciones con tus herramientas existentes.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
    </svg>`,
  },
  {
    number: '03',
    title: 'Implementación',
    desc: 'Activamos los sistemas: chatbots, hojas de cálculo y flujos N8N. Pruebas completas antes del lanzamiento.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
    </svg>`,
  },
  {
    number: '04',
    title: 'Monitoreo',
    desc: 'Supervisamos el rendimiento y optimizamos continuamente. Tu automatización siempre funcionando al máximo.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>`,
  },
];
---

<section id="proceso" class="section hiw-section">
  <div class="container">
    <h2 class="section-title reveal">
      Cómo <span class="gradient-text">Funciona</span>
    </h2>
    <p class="section-subtitle reveal">
      En 4 pasos, tu negocio opera en piloto automático
    </p>

    <div class="steps-grid">
      {steps.map((step, i) => (
        <div class="step reveal" style={`--delay: ${i * 120}ms`}>
          <!-- Connector line (not on last) -->
          {i < steps.length - 1 && (
            <div class="connector" aria-hidden="true"></div>
          )}

          <div class="step-number">{step.number}</div>

          <div class="step-icon" set:html={step.icon} />

          <div class="step-body">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw-section {
    padding-block: var(--space-2xl);
    position: relative;
  }

  .hiw-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, oklch(0.55 0.28 295 / 0.05), transparent 70%);
    pointer-events: none;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    position: relative;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
  }

  /* Step */
  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl) var(--space-md);
    position: relative;
  }

  /* Connector line (horizontal on desktop, hidden on mobile) */
  .connector {
    display: none;
  }

  @media (min-width: 768px) {
    .connector {
      display: block;
      position: absolute;
      top: 2.5rem; /* aligns with step number center */
      left: calc(50% + 2rem);
      right: calc(-50% + 2rem);
      height: 2px;
      background: var(--gradient-nebula);
      opacity: 0.4;
      z-index: 0;
    }
  }

  /* Number */
  .step-number {
    font-family: 'Orbitron', sans-serif;
    font-size: var(--text-3xl);
    font-weight: 900;
    background: var(--gradient-nebula);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: var(--space-md);
    position: relative;
    z-index: 1;
  }

  /* Icon */
  .step-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: oklch(0.14 0.04 275 / 0.8);
    border: 1px solid oklch(0.55 0.28 295 / 0.2);
    margin-bottom: var(--space-lg);
    color: oklch(0.68 0.22 295);
  }

  .step-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  /* Body */
  .step-title {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .step-desc {
    font-size: var(--text-sm);
    color: var(--clr-text-secondary);
    line-height: 1.65;
    max-width: 22ch;
    margin-inline: auto;
  }
</style>
