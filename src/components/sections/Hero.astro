---
import StarField from '../react/StarField.tsx';
---

<section id="inicio" class="hero">
  <!-- Animated star field background -->
  <StarField client:only="react" />

  <!-- Nebula gradient decorations -->
  <div class="nebula-orb orb-1" aria-hidden="true"></div>
  <div class="nebula-orb orb-2" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-text">
      <!-- Eyebrow -->
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        Inteligencia Artificial + Automatización
      </div>

      <!-- Headline -->
      <h1 class="hero-title">
        Automatiza tu negocio con
        <span class="gradient-text"> IA que trabaja por ti</span>
      </h1>

      <!-- Sub -->
      <p class="hero-sub">
        Chatbots inteligentes, integraciones con Google Sheets y flujos de trabajo con N8N.
        Tu negocio funcionando <strong>24/7</strong> sin esfuerzo.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas">
        <a href="#contacto" class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Habla con nosotros
        </a>
        <a href="#servicios" class="btn btn-outline">
          Ver servicios
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Stats strip -->
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value gradient-text">24/7</span>
          <span class="stat-label">Disponibilidad</span>
        </div>
        <div class="stat-sep" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value gradient-text">+80%</span>
          <span class="stat-label">Menos tareas manuales</span>
        </div>
        <div class="stat-sep" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value gradient-text">48h</span>
          <span class="stat-label">Implementación</span>
        </div>
      </div>
    </div>

    <!-- Decorative graphic -->
    <div class="hero-graphic" aria-hidden="true">
      <div class="orbit-ring ring-outer"></div>
      <div class="orbit-ring ring-mid"></div>
      <div class="orbit-core">
        <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="60" r="50" stroke="url(#hg1)" stroke-width="1.5" fill="none" opacity="0.4"/>
          <ellipse cx="60" cy="60" rx="40" ry="18" stroke="url(#hg2)" stroke-width="2" fill="none"/>
          <ellipse cx="60" cy="60" rx="18" ry="40" stroke="url(#hg3)" stroke-width="2" fill="none"/>
          <circle cx="60" cy="60" r="12" fill="url(#hg4)" opacity="0.9"/>
          <circle cx="60" cy="60" r="6" fill="white" opacity="0.95"/>
          <!-- orbiting dots -->
          <circle cx="60" cy="20" r="4" fill="oklch(0.72 0.16 200)" opacity="0.9"/>
          <circle cx="100" cy="60" r="3" fill="oklch(0.65 0.22 345)" opacity="0.9"/>
          <circle cx="20" cy="60" r="3" fill="oklch(0.78 0.15 60)" opacity="0.8"/>
          <defs>
            <linearGradient id="hg1" x1="10" y1="10" x2="110" y2="110">
              <stop stop-color="oklch(0.55 0.28 295)"/>
              <stop offset="1" stop-color="oklch(0.65 0.22 345)"/>
            </linearGradient>
            <linearGradient id="hg2" x1="20" y1="60" x2="100" y2="60">
              <stop stop-color="oklch(0.55 0.28 295)"/>
              <stop offset="1" stop-color="oklch(0.65 0.22 345)"/>
            </linearGradient>
            <linearGradient id="hg3" x1="60" y1="20" x2="60" y2="100">
              <stop stop-color="oklch(0.72 0.16 200)"/>
              <stop offset="1" stop-color="oklch(0.55 0.28 295)"/>
            </linearGradient>
            <radialGradient id="hg4" cx="50%" cy="50%" r="50%">
              <stop stop-color="oklch(0.65 0.22 345)"/>
              <stop offset="1" stop-color="oklch(0.55 0.28 295)"/>
            </radialGradient>
          </defs>
        </svg>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-dot"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--header-h);
  }

  /* Nebula glow orbs */
  .nebula-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    animation: nebula-breathe 8s ease-in-out infinite;
  }

  .orb-1 {
    width: min(600px, 80vw);
    height: min(600px, 80vw);
    background: radial-gradient(circle, oklch(0.55 0.28 295 / 0.25), transparent 70%);
    top: -10%;
    right: -15%;
    animation-delay: 0s;
  }

  .orb-2 {
    width: min(400px, 60vw);
    height: min(400px, 60vw);
    background: radial-gradient(circle, oklch(0.65 0.22 345 / 0.2), transparent 70%);
    bottom: 10%;
    left: -10%;
    animation-delay: 4s;
  }

  /* Content layout */
  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
    padding-block: var(--space-2xl);
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Eyebrow */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--clr-nebula-cyan);
    background: oklch(0.72 0.16 200 / 0.08);
    border: 1px solid oklch(0.72 0.16 200 / 0.25);
    border-radius: 9999px;
    padding: 0.35em 1em;
    margin-bottom: var(--space-md);
    width: fit-content;
  }

  .eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--clr-nebula-cyan);
    animation: nebula-breathe 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* Headline */
  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    max-width: 52ch;
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .hero-sub strong {
    color: var(--clr-nebula-cyan);
    font-weight: 700;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  /* Stats strip */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-value {
    font-family: 'Orbitron', sans-serif;
    font-size: var(--text-2xl);
    font-weight: 800;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--clr-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-sep {
    width: 1px;
    height: 40px;
    background: oklch(0.55 0.28 295 / 0.25);
    flex-shrink: 0;
  }

  /* Hero graphic */
  .hero-graphic {
    display: none;
    position: relative;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-graphic { display: flex; }
  }

  .orbit-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid oklch(0.55 0.28 295 / 0.15);
    animation: spin-slow linear infinite;
  }

  .ring-outer {
    width: 320px;
    height: 320px;
    animation-duration: 30s;
  }

  .ring-mid {
    width: 220px;
    height: 220px;
    animation-duration: 20s;
    animation-direction: reverse;
    border-color: oklch(0.65 0.22 345 / 0.12);
  }

  .orbit-core {
    width: 200px;
    height: 200px;
    animation: float 6s ease-in-out infinite;
    filter: drop-shadow(var(--glow-violet));
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    width: 24px;
    height: 40px;
    border: 2px solid oklch(0.55 0.28 295 / 0.35);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: var(--gradient-nebula);
    border-radius: 2px;
    animation: float 2s ease-in-out infinite;
  }
</style>
