---
import StarField from '../react/StarField.tsx';
---

<section id="inicio" class="hero">
  <StarField client:only="react" />

  <!-- mesh blobs -->
  <div class="blob b1" aria-hidden="true"></div>
  <div class="blob b2" aria-hidden="true"></div>
  <div class="blob b3" aria-hidden="true"></div>

  <!-- grid overlay -->
  <div class="grid-lines" aria-hidden="true"></div>

  <div class="wrap hero-wrap">
    <div class="hero-body">

      <!-- Badge -->
      <div class="badge reveal">
        <span class="badge-dot"></span>
        IA + N8N + Automatización Empresarial
      </div>

      <!-- Title -->
      <h1 class="hero-h reveal">
        Automatiza tu negocio con
        <br/>
        <span class="hero-grad">IA que trabaja</span>
        <br/>
        <span class="hero-grad2">las 24 horas</span>
      </h1>

      <!-- Subtitle -->
      <p class="hero-p reveal">
        Chatbots inteligentes, integraciones con Google&nbsp;Sheets y flujos N8N.<br/>
        Menos trabajo manual, más resultados — desde el primer día.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas reveal">
        <a href="#contacto" class="btn btn-primary hero-btn-p">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Habla con nosotros
        </a>
        <a href="#servicios" class="btn btn-ghost">
          Ver servicios
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="stats reveal">
        <div class="stat">
          <span class="stat-n grad">24/7</span>
          <span class="stat-l">Disponibilidad</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-n grad">+80%</span>
          <span class="stat-l">Menos tareas manuales</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-n grad">48h</span>
          <span class="stat-l">Implementación</span>
        </div>
      </div>
    </div>

    <!-- Right visual -->
    <div class="hero-visual reveal" aria-hidden="true">
      <!-- Floating dashboard card -->
      <div class="dash-card">
        <div class="dash-hdr">
          <div class="dash-dots">
            <span style="background:#ff5f57"></span>
            <span style="background:#febc2e"></span>
            <span style="background:#28c840"></span>
          </div>
          <span class="dash-title">Nebula Dashboard</span>
        </div>
        <div class="dash-body">
          <div class="dash-metric">
            <span class="dm-label">Automatizaciones activas</span>
            <span class="dm-val grad">24</span>
          </div>
          <div class="dash-bar-wrap">
            <div class="dash-bar" style="--w:85%"></div>
            <div class="dash-bar" style="--w:62%"></div>
            <div class="dash-bar" style="--w:91%"></div>
            <div class="dash-bar" style="--w:47%"></div>
          </div>
          <div class="dash-row">
            <div class="dash-chip chip-green">● Chatbot activo</div>
            <div class="dash-chip chip-violet">● 3 flujos N8N</div>
          </div>
          <div class="dash-row" style="margin-top:.5rem">
            <div class="dash-chip chip-cyan">● Sheets sync</div>
            <div class="dash-chip chip-pink">● 142 leads hoy</div>
          </div>
        </div>
      </div>

      <!-- Orbiting decoration -->
      <div class="orb-ring r1"></div>
      <div class="orb-ring r2"></div>
    </div>
  </div>

  <!-- scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--hdr);
  }

  /* Mesh blobs */
  .blob {
    position: absolute; border-radius: 50%;
    filter: blur(100px); pointer-events: none;
    animation: pulse-glow 10s ease-in-out infinite;
  }
  .b1 { width:700px; height:700px; background:rgba(139,92,246,.18); top:-15%; right:-10%; animation-delay:0s; }
  .b2 { width:500px; height:500px; background:rgba(236,72,153,.13); bottom:-10%; left:-8%;  animation-delay:4s; }
  .b3 { width:350px; height:350px; background:rgba(34,211,238,.09);  top:40%;    left:35%;  animation-delay:7s; }

  /* Grid overlay */
  .grid-lines {
    position:absolute; inset:0; pointer-events:none;
    background-image:
      linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  /* Layout */
  .hero-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    padding-block: clamp(4rem, 8vw, 6rem);
    position: relative; z-index: 1;
  }
  @media(min-width:900px){ .hero-wrap { grid-template-columns:1fr 1fr; } }

  /* Badge */
  .badge {
    display:inline-flex; align-items:center; gap:.5rem;
    font-size:.72rem; font-weight:600; letter-spacing:.07em; text-transform:uppercase;
    color:#a78bfa; background:rgba(139,92,246,.1);
    border:1px solid rgba(139,92,246,.3); border-radius:999px;
    padding:.35em 1em; margin-bottom:1.25rem; width:fit-content;
  }
  .badge-dot { width:7px; height:7px; border-radius:50%; background:#8b5cf6; animation:pulse-glow 2s ease-in-out infinite; flex-shrink:0; }

  /* Title */
  .hero-h {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: 1.07;
    margin-bottom: 1.4rem;
    color: var(--white);
  }
  .hero-grad {
    background: linear-gradient(90deg,#8b5cf6,#ec4899,#f59e0b);
    background-size: 200% auto;
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
    animation: shimmer 4s linear infinite;
  }
  .hero-grad2 {
    background: linear-gradient(90deg,#22d3ee,#8b5cf6,#ec4899);
    background-size: 200% auto;
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
    animation: shimmer 4s linear infinite reverse;
  }

  /* Subtitle */
  .hero-p {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: var(--gray-1);
    max-width: 50ch;
    margin-bottom: 2.2rem;
    line-height: 1.75;
  }

  /* CTAs */
  .hero-ctas { display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:2.8rem; }
  .hero-btn-p { font-size:1rem; padding:.8em 2em; }

  /* Stats */
  .stats { display:flex; align-items:center; gap:1.75rem; flex-wrap:wrap; }
  .stat { display:flex; flex-direction:column; gap:3px; }
  .stat-n { font-family:'Syne',sans-serif; font-size:1.7rem; font-weight:800; line-height:1; }
  .stat-l { font-size:.72rem; color:var(--gray-2); text-transform:uppercase; letter-spacing:.06em; }
  .stat-div { width:1px; height:36px; background:var(--border); flex-shrink:0; }

  /* Dashboard card */
  .hero-visual {
    position:relative; display:flex; align-items:center; justify-content:center;
  }
  .dash-card {
    width:min(380px,90vw);
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.1);
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 32px 80px rgba(0,0,0,.5), 0 0 0 1px rgba(139,92,246,.15) inset;
    animation: float-y 6s ease-in-out infinite;
    position:relative; z-index:2;
    backdrop-filter:blur(20px);
  }
  .dash-hdr {
    display:flex; align-items:center; gap:.75rem;
    padding:.85rem 1.2rem;
    border-bottom:1px solid rgba(255,255,255,.06);
    background:rgba(255,255,255,.02);
  }
  .dash-dots { display:flex; gap:6px; }
  .dash-dots span { width:10px; height:10px; border-radius:50%; }
  .dash-title { font-size:.75rem; color:var(--gray-2); font-weight:500; margin-left:.25rem; }
  .dash-body { padding:1.4rem 1.2rem; display:flex; flex-direction:column; gap:1.2rem; }
  .dash-metric { display:flex; justify-content:space-between; align-items:center; }
  .dm-label { font-size:.8rem; color:var(--gray-1); }
  .dm-val { font-family:'Syne',sans-serif; font-size:2rem; font-weight:800; }
  .dash-bar-wrap { display:flex; flex-direction:column; gap:.55rem; }
  .dash-bar {
    height:8px; border-radius:999px;
    background:linear-gradient(90deg,#8b5cf6,#ec4899);
    width:var(--w); opacity:.7;
    position:relative; overflow:hidden;
  }
  .dash-bar::after {
    content:''; position:absolute; inset:0;
    background:linear-gradient(90deg,transparent 40%,rgba(255,255,255,.3),transparent 60%);
    animation:shimmer 2.5s linear infinite;
    background-size:200% 100%;
  }
  .dash-row { display:flex; gap:.6rem; flex-wrap:wrap; }
  .dash-chip {
    font-size:.7rem; font-weight:600; border-radius:999px;
    padding:.25em .85em; border:1px solid;
  }
  .chip-green  { color:#4ade80; border-color:rgba(74,222,128,.3); background:rgba(74,222,128,.08); }
  .chip-violet { color:#a78bfa; border-color:rgba(167,139,250,.3); background:rgba(167,139,250,.08); }
  .chip-cyan   { color:#22d3ee; border-color:rgba(34,211,238,.3);  background:rgba(34,211,238,.08); }
  .chip-pink   { color:#f472b6; border-color:rgba(244,114,182,.3); background:rgba(244,114,182,.08); }

  /* Orbiting rings */
  .orb-ring {
    position:absolute; border-radius:50%; border:1px solid;
    pointer-events:none;
  }
  .r1 { width:440px;height:440px; border-color:rgba(139,92,246,.12); animation:spin-cw 30s linear infinite; }
  .r2 { width:340px;height:340px; border-color:rgba(236,72,153,.1); animation:spin-ccw 20s linear infinite; }

  /* Scroll cue */
  .scroll-cue { position:absolute; bottom:2rem; left:50%; transform:translateX(-50%); }
  .scroll-mouse {
    width:22px; height:36px; border:1.5px solid rgba(255,255,255,.25);
    border-radius:11px; display:flex; justify-content:center; padding-top:6px;
  }
  .scroll-wheel { width:3px; height:7px; background:rgba(255,255,255,.5); border-radius:2px; animation:float-y 1.8s ease-in-out infinite; }
</style>
