---
import ContactForm from '../react/ContactForm.tsx';
---

<section id="contacto" class="sec contact-sec">
  <div class="blob-contact" aria-hidden="true"></div>
  <div class="wrap">
    <div class="sec-tag reveal" style="margin-inline:auto"><span></span>Contacto</div>
    <h2 class="sec-h reveal">
      Comienza <span class="grad">hoy mismo</span>
    </h2>
    <p class="sec-sub reveal">
      Cuéntanos sobre tu negocio y en menos de 24 horas te proponemos cómo automatizarlo — gratis, sin compromiso.
    </p>

    <div class="contact-grid">
      <!-- Info -->
      <div class="ci reveal">
        <h3 class="ci-title">¿Listo para automatizar?</h3>
        <p class="ci-text">
          Nuestro equipo analiza tu caso personalmente y te entrega una propuesta clara con los flujos de automatización ideales para tu operación.
        </p>

        <ul class="ci-list">
          {[
            'Consultoría inicial 100% gratuita',
            'Respuesta en menos de 24 horas',
            'Propuesta personalizada para tu negocio',
            'Sin contratos de largo plazo al inicio',
          ].map(item => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>

        <!-- Mini testimonial -->
        <div class="testimonial">
          <div class="test-stars">★★★★★</div>
          <p class="test-text">"Redujimos 15 horas semanales de trabajo manual en solo 3 días de implementación."</p>
          <div class="test-author">
            <div class="test-avatar">MR</div>
            <div>
              <span class="test-name">María Rodríguez</span>
              <span class="test-role">Gerente de Operaciones</span>
            </div>
          </div>
        </div>

        <a href="mailto:castroronal718@gmail.com" class="ci-email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          castroronal718@gmail.com
        </a>
      </div>

      <!-- Form -->
      <div class="cf-wrap reveal" style="--delay:150ms">
        <div class="cf-inner">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-sec { position:relative; overflow:hidden; }
  .blob-contact {
    position:absolute; width:700px; height:500px;
    background:radial-gradient(ellipse, rgba(139,92,246,.07) 0%, transparent 70%);
    bottom:-10%; left:50%; transform:translateX(-50%);
    pointer-events:none;
  }

  .contact-grid {
    display:grid; grid-template-columns:1fr; gap:2rem;
    position:relative; z-index:1;
  }
  @media(min-width:900px){ .contact-grid{ grid-template-columns:1fr 1.3fr; align-items:start; } }

  /* Info side */
  .ci-title {
    font-family:'Syne',sans-serif; font-size:1.5rem; font-weight:800;
    margin-bottom:.75rem;
  }
  .ci-text {
    font-size:.9rem; color:var(--gray-1); line-height:1.75; margin-bottom:1.75rem;
  }
  .ci-list { list-style:none; display:flex; flex-direction:column; gap:.75rem; margin-bottom:2rem; }
  .ci-list li {
    display:flex; align-items:center; gap:.6rem;
    font-size:.9rem; color:var(--gray-1);
  }
  .ci-list li svg { color:#8b5cf6; flex-shrink:0; }

  /* Testimonial */
  .testimonial {
    background:rgba(255,255,255,.03);
    border:1px solid rgba(255,255,255,.08);
    border-left:3px solid #8b5cf6;
    border-radius:12px;
    padding:1.25rem;
    margin-bottom:1.75rem;
  }
  .test-stars { color:#f59e0b; font-size:.9rem; margin-bottom:.5rem; letter-spacing:.05em; }
  .test-text { font-size:.85rem; color:var(--gray-1); line-height:1.65; margin-bottom:1rem; font-style:italic; }
  .test-author { display:flex; align-items:center; gap:.75rem; }
  .test-avatar {
    width:36px; height:36px; border-radius:50%;
    background:linear-gradient(135deg,#8b5cf6,#ec4899);
    display:flex; align-items:center; justify-content:center;
    font-size:.7rem; font-weight:700; color:#fff; flex-shrink:0;
  }
  .test-name { display:block; font-size:.82rem; font-weight:600; }
  .test-role { font-size:.72rem; color:var(--gray-2); }

  .ci-email {
    display:inline-flex; align-items:center; gap:.5rem;
    font-size:.875rem; color:#22d3ee; font-weight:500;
    transition:color var(--t);
  }
  .ci-email:hover { color:#67e8f9; }

  /* Form wrapper */
  .cf-wrap { transition-delay: var(--delay,0ms); }
  .cf-inner {
    background:rgba(255,255,255,.03);
    border:1px solid rgba(255,255,255,.08);
    border-radius:20px;
    padding:clamp(1.5rem,3vw,2rem);
    backdrop-filter:blur(20px);
  }
</style>
