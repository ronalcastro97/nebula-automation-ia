---
const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>`,
    color: '#8b5cf6', colorAlpha: 'rgba(139,92,246,.12)', colorBorder: 'rgba(139,92,246,.3)',
    tag: 'Datos',
    title: 'Automatización de Datos',
    description: 'Organiza archivos, categoriza información y limpia hojas de cálculo automáticamente. Elimina el 90% del trabajo manual repetitivo.',
    features: ['Organización automática', 'Limpieza de datos', 'Reportes automáticos'],
    size: 'large',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><circle cx="9" cy="10" r="1" fill="currentColor"/><circle cx="12" cy="10" r="1" fill="currentColor"/><circle cx="15" cy="10" r="1" fill="currentColor"/></svg>`,
    color: '#ec4899', colorAlpha: 'rgba(236,72,153,.12)', colorBorder: 'rgba(236,72,153,.3)',
    tag: 'Chatbots',
    title: 'Chatbots Empresariales',
    description: 'Bots que gestionan citas, ventas, compras y bases de datos — operando 24/7 sin intervención humana.',
    features: ['Citas y reservas', 'Ventas automatizadas', 'Soporte 24/7'],
    size: 'normal',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>`,
    color: '#22d3ee', colorAlpha: 'rgba(34,211,238,.12)', colorBorder: 'rgba(34,211,238,.3)',
    tag: 'Integraciones',
    title: 'Google Sheets & Excel',
    description: 'Sincronización en tiempo real con tus hojas de cálculo. Reportes que se actualizan solos.',
    features: ['Sync en tiempo real', 'Dashboards automáticos'],
    size: 'normal',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    color: '#f59e0b', colorAlpha: 'rgba(245,158,11,.12)', colorBorder: 'rgba(245,158,11,.3)',
    tag: 'Web',
    title: 'Páginas Web con Chatbot',
    description: 'Sitios web completos con chatbot integrado. Tu presencia digital que convierte visitantes en clientes automáticamente.',
    features: ['Web + chatbot integrado', 'Captación de leads', 'Automatización total'],
    size: 'large',
  },
];
---

<section id="servicios" class="sec">
  <div class="wrap">
    <div class="sec-tag reveal"><span></span>Servicios</div>
    <h2 class="sec-h reveal">
      Todo lo que tu negocio<br/><span class="grad">necesita automatizar</span>
    </h2>
    <p class="sec-sub reveal">
      Desde organizar archivos hasta crear un sistema de ventas completo — lo hacemos funcionar mientras tú te enfocas en crecer.
    </p>

    <!-- Bento grid -->
    <div class="bento reveal">
      {services.map((s) => (
        <article
          class={`bento-card bc-${s.size}`}
          style={`--c:${s.color}; --ca:${s.colorAlpha}; --cb:${s.colorBorder};`}
        >
          <div class="bc-icon" set:html={s.icon} />
          <div class="bc-tag">{s.tag}</div>
          <h3 class="bc-title">{s.title}</h3>
          <p class="bc-desc">{s.description}</p>
          <ul class="bc-feats">
            {s.features.map(f => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <div class="bc-glow" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Bento grid */
  .bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media(min-width:640px){ .bento{ grid-template-columns:repeat(2,1fr); } }
  @media(min-width:1024px){
    .bento {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
    }
    .bc-large:first-child { grid-column: span 2; }
    .bc-large:last-child  { grid-column: span 2; }
  }

  /* Card */
  .bento-card {
    position: relative; overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: clamp(1.5rem, 3vw, 2rem);
    transition: border-color var(--t), background var(--t), transform var(--t), box-shadow var(--t);
  }
  .bento-card:hover {
    border-color: var(--cb);
    background: var(--ca);
    transform: translateY(-5px);
    box-shadow: 0 24px 60px rgba(0,0,0,.35), 0 0 40px color-mix(in srgb, var(--c) 20%, transparent);
  }

  .bc-icon {
    width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 14px;
    background: var(--ca); border: 1px solid var(--cb);
    color: var(--c);
    margin-bottom: 1.25rem;
  }
  .bc-icon :global(svg) { width:26px; height:26px; }

  .bc-tag {
    font-size:.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
    color:var(--c); margin-bottom:.5rem;
  }
  .bc-title {
    font-family:'Syne',sans-serif; font-size:1.2rem; font-weight:800;
    margin-bottom:.65rem; color:var(--white);
  }
  .bc-desc {
    font-size:.9rem; color:var(--gray-1); line-height:1.7; margin-bottom:1.2rem;
  }
  .bc-feats {
    list-style:none; display:flex; flex-direction:column; gap:.45rem;
  }
  .bc-feats li {
    display:flex; align-items:center; gap:.5rem;
    font-size:.8rem; color:var(--gray-2);
  }
  .bc-feats li svg { color:var(--c); flex-shrink:0; }

  /* Glow overlay on hover */
  .bc-glow {
    position:absolute; inset:0; opacity:0; pointer-events:none; transition:opacity var(--t);
    background: radial-gradient(circle at 20% 20%, color-mix(in srgb, var(--c) 12%, transparent), transparent 65%);
  }
  .bento-card:hover .bc-glow { opacity:1; }
</style>
