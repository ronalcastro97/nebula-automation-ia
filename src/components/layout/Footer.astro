---
const year = new Date().getFullYear();
const links = [
  { label:'Servicios', href:'#servicios' },
  { label:'Proceso',   href:'#proceso'   },
  { label:'Beneficios',href:'#beneficios'},
  { label:'Contacto',  href:'#contacto'  },
];
---

<footer>
  <div class="wrap ft-inner">
    <div class="ft-brand">
      <a href="#inicio" class="ft-logo">
        Nebula<span class="grad"> AI</span>
      </a>
      <p class="ft-tagline">Automatización inteligente para negocios modernos.</p>
    </div>

    <nav class="ft-nav">
      <span class="ft-nav-hd">Navegación</span>
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="ft-contact">
      <span class="ft-nav-hd">Contacto</span>
      <a href="mailto:hola@nebulaautomation.ia" class="ft-email">hola@nebulaautomation.ia</a>
    </div>
  </div>

  <!-- Divider -->
  <div class="ft-div"></div>

  <div class="wrap ft-bottom">
    <p>© {year} Nebula Automation IA. Todos los derechos reservados.</p>
    <p>Construido con <span class="grad">Astro + React</span></p>
  </div>
</footer>

<style>
  footer {
    border-top:1px solid var(--border);
    padding-top:clamp(2.5rem,6vw,4rem);
    margin-top:clamp(2rem,4vw,3rem);
  }
  .ft-inner {
    display:grid; grid-template-columns:1fr; gap:2.5rem;
    padding-bottom:2.5rem;
  }
  @media(min-width:640px){ .ft-inner{ grid-template-columns:2fr 1fr 1fr; } }

  .ft-logo {
    font-family:'Syne',sans-serif; font-size:1.2rem; font-weight:800;
    color:var(--white); display:inline-block; margin-bottom:.6rem;
  }
  .ft-tagline { font-size:.85rem; color:var(--gray-2); max-width:28ch; line-height:1.5; }

  .ft-nav-hd {
    display:block; font-size:.7rem; font-weight:700;
    text-transform:uppercase; letter-spacing:.1em;
    color:var(--gray-2); margin-bottom:.85rem;
  }
  .ft-nav { display:flex; flex-direction:column; gap:.55rem; }
  .ft-nav a { font-size:.875rem; color:var(--gray-1); transition:color var(--t); }
  .ft-nav a:hover { color:#a78bfa; }

  .ft-contact { display:flex; flex-direction:column; }
  .ft-email { font-size:.875rem; color:var(--gray-1); transition:color var(--t); word-break:break-all; }
  .ft-email:hover { color:#22d3ee; }

  .ft-div { height:1px; background:var(--border); margin:0 clamp(1.25rem,5vw,3rem); }

  .ft-bottom {
    display:flex; flex-wrap:wrap; justify-content:space-between; gap:.5rem;
    padding-block:1.5rem;
    font-size:.78rem; color:var(--gray-2);
  }
</style>
